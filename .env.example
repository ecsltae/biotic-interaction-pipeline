# Copy to .env and fill in before deploying
# docker run --env-file .env ...

# Required: path to the HuggingFace model directory on the host
MODEL_DIR=/opt/biotic/models/distilled_BiomedBERT_v2

# Optional
PORT=8003
DEFAULT_THRESHOLD=0.25
DEVICE=auto        # auto | cuda:0 | cpu

# For process_articles.py
CLASSIFIER_API=http://localhost:8003
