# Biotic Interaction Pipeline Configuration
# Generated by Ansible — edit deploy/group_vars/all.yml to change values

[server]
host = "{{ biotic_host }}"
port = {{ biotic_port }}
workers = {{ biotic_workers }}
log_level = "{{ biotic_log_level }}"

[model]
model_dir = "{{ biotic_model_dir }}"
device = "{{ biotic_device }}"
threshold = {{ biotic_threshold }}
max_length = {{ biotic_max_length }}

[data]
interaction_dict = "{{ biotic_interaction_dict }}"
species_dict = "{{ biotic_species_dict }}"
